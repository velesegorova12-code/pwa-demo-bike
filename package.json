{
  "name": "cycle_route_planner_web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "i18n:extract": "i18next-cli extract --config i18next-cli.config.ts",
    "i18n:lint": "i18next-cli lint --config i18next-cli.config.ts",
    "preview": "vite preview",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-query-devtools": "^5.62.7",
    "@turf/bbox": "^7.3.4",
    "@turf/length": "^7.3.4",
    "@turf/turf": "^7.3.4",
    "axios": "^1.13.2",
    "i18next": "^23.15.1",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-http-backend": "^2.7.1",
    "maplibre-gl": "^5.22.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^15.4.0",
    "react-map-gl": "^8.1.0",
    "react-router-dom": "^7.1.5",
    "styled-components": "^6.1.15",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tanstack/eslint-plugin-query": "^5.62.7",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "i18next-cli": "^1.30.5",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run i18n:extract && git add public/locales && npx lint-staged",
    "pre-push": "npm run lint"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
